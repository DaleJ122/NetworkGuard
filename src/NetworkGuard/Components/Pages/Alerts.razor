@page "/alerts"
@rendermode InteractiveServer
@inject IAlertService AlertService
@inject IDbContextFactory<AppDbContext> DbFactory
@implements IDisposable

<PageTitle>NetworkGuard - Alerts</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">
        Alerts
        @if (_unreadCount > 0)
        {
            <span class="badge bg-danger fs-6 ms-2">@_unreadCount unread</span>
        }
    </h2>
    @if (_unreadCount > 0)
    {
        <button class="btn btn-outline-primary" @onclick="MarkAllRead">
            <i class="bi bi-check-all"></i> Mark All Read
        </button>
    }
</div>

<div class="card">
    <div class="card-body p-0">
        @if (_alerts.Count == 0)
        {
            <div class="p-4 text-center text-muted">
                <i class="bi bi-check-circle fs-1"></i>
                <p class="mt-2">No alerts. All clear!</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 40px;"></th>
                            <th>Time</th>
                            <th>Device</th>
                            <th>Domain</th>
                            <th>Category</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var alert in _alerts)
                        {
                            <tr class="@(!alert.IsRead ? "table-warning fw-bold" : "")">
                                <td>
                                    @if (!alert.IsRead)
                                    {
                                        <i class="bi bi-circle-fill text-danger" style="font-size: 0.5rem;"></i>
                                    }
                                </td>
                                <td>@alert.Timestamp.ToLocalTime().ToString("g")</td>
                                <td>@(alert.Device?.DisplayName ?? "Unknown")</td>
                                <td><code>@alert.Domain</code></td>
                                <td>
                                    <span class="badge @GetCategoryBadgeClass(alert.Category)">@alert.Category</span>
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        @if (!alert.IsRead)
                                        {
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => MarkRead(alert.Id)" title="Mark as read">
                                                <i class="bi bi-check"></i>
                                            </button>
                                        }
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DismissAlert(alert.Id)" title="Dismiss alert">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private List<Alert> _alerts = new();
    private int _unreadCount;

    private Timer? _refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();

        _refreshTimer = new Timer(async _ =>
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    await LoadDataAsync();
                    StateHasChanged();
                });
            }
            catch (Exception) { }
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private async Task LoadDataAsync()
    {
        _alerts = await AlertService.GetRecentAlertsAsync(100);
        _unreadCount = await AlertService.GetUnreadCountAsync();
    }

    private async Task MarkRead(int alertId)
    {
        await AlertService.MarkAsReadAsync(alertId);
        await LoadDataAsync();
    }

    private async Task MarkAllRead()
    {
        await AlertService.MarkAllAsReadAsync();
        await LoadDataAsync();
    }

    private async Task DismissAlert(int alertId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        await db.Alerts.Where(a => a.Id == alertId).ExecuteDeleteAsync();
        await LoadDataAsync();
    }

    private static string GetCategoryBadgeClass(string category) => category.ToLowerInvariant() switch
    {
        "adult" => "bg-danger",
        "gambling" => "bg-warning text-dark",
        "hacking" => "bg-info",
        "malware" => "bg-dark",
        "drugs" => "bg-success",
        "violence" => "bg-danger",
        "vpn-proxy" => "bg-primary",
        "dating" => "bg-pink",
        _ => "bg-secondary"
    };

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}
