@inherits LayoutComponentBase

<div class="d-flex">
    <!-- Mobile overlay backdrop -->
    <div class="sidebar-overlay" onclick="sidebarToggle.close()"></div>

    <!-- Mobile top bar -->
    <div class="mobile-topbar d-md-none">
        <button class="btn btn-dark border-0 p-2" onclick="sidebarToggle.toggle()" aria-label="Toggle navigation">
            <i class="bi bi-list fs-4"></i>
        </button>
        <a href="/" class="d-flex align-items-center text-white text-decoration-none">
            <i class="bi bi-shield-check me-2 fs-5"></i>
            <span class="fs-5 fw-bold">NetworkGuard</span>
        </a>
        <div style="width: 40px;"></div>
    </div>

    <NavMenu />
    <main class="flex-grow-1 main-content" style="overflow-y: auto; max-height: 100vh;">
        <div style="max-width: 1400px;">
            @Body
        </div>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
