{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=networkguard.db"
  },
  "Dns": {
    "ListenIp": "0.0.0.0",
    "ListenPort": 53,
    "UpstreamServer": "8.8.8.8",
    "UpstreamPort": 53
  },
  "Database": {
    "UnflaggedRetentionHours": 12,
    "FlaggedRetentionDays": 7,
    "AlertRetentionDays": 7
  }
}
